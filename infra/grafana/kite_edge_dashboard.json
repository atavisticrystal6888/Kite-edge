{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "title": "KiteEdge – Platform Health (T196)",
  "uid": "kite-edge-health",
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "rate(http_requests_total[1m])", "legendFormat": "{{method}} {{path}}" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "HTTP Latency p95",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95" }],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Kite API Calls",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "sum(rate(kite_api_calls_total[1m]))", "legendFormat": "req/s" }],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 }
    },
    {
      "title": "WebSocket Connections",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "websocket_connections_active", "legendFormat": "active" }],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 }
    },
    {
      "title": "Redis Memory",
      "type": "gauge",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "redis_memory_used_bytes", "legendFormat": "used" }],
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 }
    },
    {
      "title": "PostgreSQL Connections",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "targets": [{ "expr": "pg_stat_activity_count", "legendFormat": "conns" }],
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 }
    }
  ],
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s"
}
