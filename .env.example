# KiteEdge environment template.
# Copy to `.env` and fill in secrets. Do NOT commit `.env`.
# Kite API credentials are never persisted to PostgreSQL; they live only in
# Redis (ephemeral session) and process memory. See constitution.md Principle 7.

# ---- Application ----
KITEEDGE_ENV=dev
SECRET_KEY_BASE=replace-me-with-64-byte-random-hex
PHX_HOST=localhost
PHX_PORT=4000

# ---- PostgreSQL ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=kiteedge
POSTGRES_PASSWORD=kiteedge
POSTGRES_DB=kiteedge
DATABASE_URL=ecto://kiteedge:kiteedge@postgres:5432/kiteedge

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ---- Zerodha Kite ----
# Obtain from https://developers.kite.trade/apps
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=http://localhost:4000/auth/kite/callback
# Request pacing: Kite allows 3 req/sec. Do not raise. See Principle 1.
KITE_RATE_LIMIT_PER_SECOND=3

# ---- Analytics engine ----
ANALYTICS_ENGINE_URL=http://analytics_engine:8001
ANALYTICS_ENGINE_TIMEOUT_MS=15000

# ---- Notification ----
NOTIFY_EMAIL_ENABLED=false
NOTIFY_EMAIL_FROM=alerts@kiteedge.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true

# ---- Observability ----
LOG_LEVEL=info
PROMETHEUS_ENABLED=true
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
